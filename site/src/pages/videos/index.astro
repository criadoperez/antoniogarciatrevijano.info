---
import Base from "../../layouts/Base.astro";
import videoData from "../../data/videos.json";

const { channels, total, videos: rawVideos } = videoData;
const videos = [...rawVideos].reverse();
---

<Base title="Vídeos" description={`${total} vídeos de Antonio García-Trevijano`}>
  <h1 class="text-3xl font-bold font-serif text-brand-900 mb-2">Vídeos</h1>
  <p class="text-gray-600 mb-6">{total} vídeos de conferencias, entrevistas y programas de Radio Libertad Constituyente.</p>

  <!-- Channel filter -->
  <div class="flex flex-wrap gap-3 mb-6">
    <select id="filter-channel" aria-label="Filtrar por canal" class="border border-gray-300 rounded px-3 py-2 text-sm bg-white">
      <option value="">Todos los canales</option>
      {channels.map((ch) => <option value={ch}>{ch}</option>)}
    </select>
    <span id="filter-count" class="self-center text-sm text-gray-500"></span>
  </div>

  <!-- Video list -->
  <div id="video-list" class="space-y-1">
    {videos.map((video) => (
      <a
        href={`/videos/${video.id}/`}
        class="video-row block px-3 py-2.5 rounded hover:bg-brand-50 transition-colors border-b border-gray-100"
        data-channel={video.channel_display}
        data-pagefind-ignore
      >
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-1">
          <span class="text-sm text-gray-400 font-mono shrink-0 w-24">{video.date || "s/f"}</span>
          <span class="text-xs text-brand-700 bg-brand-50 px-2 py-0.5 rounded shrink-0">
            {video.channel_display}
          </span>
          <span class="font-medium text-gray-900 flex-1">{video.title}</span>
          <span class="text-xs text-gray-400 shrink-0">{video.duration_formatted}</span>
        </div>
      </a>
    ))}
  </div>
</Base>

<script is:inline>
  (function () {
    const select = document.getElementById("filter-channel");
    const rows = document.querySelectorAll(".video-row");
    const countEl = document.getElementById("filter-count");
    if (!select || !rows.length) return;

    function applyFilter() {
      const ch = select.value;
      let visible = 0;
      rows.forEach((row) => {
        const match = !ch || row.dataset.channel === ch;
        row.style.display = match ? "" : "none";
        if (match) visible++;
      });
      countEl.textContent = ch ? `${visible} vídeos` : "";
    }

    select.addEventListener("change", applyFilter);
  })();
</script>
