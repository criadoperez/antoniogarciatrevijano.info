---
import Base from "../../layouts/Base.astro";
import videoData from "../../data/videos.json";

export function getStaticPaths() {
  return videoData.videos.map((video) => ({
    params: { id: video.id },
    props: { video },
  }));
}

const { video } = Astro.props;
---

<Base title={video.title} description={`${video.title} — Vídeo`}>
  <div class="max-w-3xl mx-auto">

    <nav class="text-sm text-gray-500 mb-4">
      <a href="/videos/" class="hover:text-brand-700">Vídeos</a>
      <span class="mx-1">/</span>
      <span class="text-gray-700 line-clamp-1">{video.title}</span>
    </nav>

    <h1 class="text-2xl font-bold font-serif text-brand-900 mb-3 leading-snug">
      {video.title}
    </h1>

    <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-gray-500 mb-6">
      {video.date && <span>{video.date}</span>}
      <span>{video.channel}</span>
      <span>{video.duration_formatted}</span>
      <a href={video.youtube_url} target="_blank" rel="noopener" class="hover:text-brand-700">
        YouTube &#8599;
      </a>
    </div>

    <!-- Thumbnail linking to YouTube -->
    <a href={video.youtube_url} target="_blank" rel="noopener" class="block mb-6 group">
      <div class="relative rounded-lg overflow-hidden shadow-md">
        <img
          src={video.thumbnail}
          alt={video.title}
          class="w-full aspect-video object-cover group-hover:opacity-90 transition-opacity"
          loading="lazy"
        />
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="w-16 h-16 bg-black/60 rounded-full flex items-center justify-center group-hover:bg-red-600/80 transition-colors">
            <svg class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </div>
        </div>
      </div>
    </a>

    <!-- Audio link if available -->
    {video.audio_id && (
      <div class="bg-brand-50 border border-brand-200 rounded-lg px-4 py-3 mb-6">
        <a href={`/audios/${video.audio_id}/`} class="text-brand-700 hover:text-brand-900 font-medium">
          &#127911; También disponible en audio
        </a>
      </div>
    )}

    <!-- Transcript placeholder -->
    <div class="border-t border-gray-200 pt-6" data-pagefind-body>
      <h2 class="text-lg font-bold font-serif text-brand-900 mb-3">Transcripción</h2>
      <p class="text-gray-400 text-sm italic">
        Transcripciones del video estarán disponibles próximamente.
      </p>
    </div>

  </div>
</Base>
