---
import { join } from "node:path";
import Base from "../../layouts/Base.astro";
import { loadAllAudios, formatDuration } from "../../lib/audio";

const audiosDir = join(process.cwd(), "..", "ficheros", "publicos", "audios");
const audios = loadAllAudios(audiosDir);

// Group by year — audios already sorted oldest → newest by loadAllAudios
const byYear = new Map<string, typeof audios>();
for (const audio of audios) {
  const year = audio.date.slice(0, 4) || "sin-fecha";
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(audio);
}
const years = [...byYear.keys()].sort();

// Group years by decade for sidebar navigation
const byDecade = new Map<string, string[]>();
for (const y of years) {
  if (y === "sin-fecha") continue;
  const d = y.slice(0, 3) + "0s";
  if (!byDecade.has(d)) byDecade.set(d, []);
  byDecade.get(d)!.push(y);
}
---

<Base title="Audios" description="Grabaciones de Radio Libertad Constituyente">
  <div class="max-w-5xl">
    <h1 class="text-3xl font-bold font-serif text-brand-900 mb-2">Audios</h1>
    <p class="text-gray-600 mb-8">
      Grabaciones de Radio Libertad Constituyente, el programa del MCRC en iVoox
      con miles de emisiones sobre democracia, república y la obra de García-Trevijano.
    </p>

    <a
      href="https://www.ivoox.com/en/podcast-radio-libertad-constituyente_sq_f125183_93.html"
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-3 px-6 py-4 bg-brand-900 text-white rounded-lg hover:bg-brand-800 transition-colors text-lg"
    >
      Escuchar en iVoox
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>

    {audios.length > 0 && (
      <>
        <div class="flex items-center gap-4 mt-12 mb-4">
          <h2 class="text-xl font-bold font-serif text-brand-900 shrink-0">Transcripciones</h2>
          <div class="flex-1 h-px bg-gray-200" />
          <span class="text-sm text-gray-400 shrink-0">{audios.length} audios</span>
        </div>

        <!-- Mobile: year jump -->
        <div class="lg:hidden mb-6">
          <select
            id="year-jump"
            class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-700 focus:border-brand-700 focus:outline-none"
          >
            <option value="">Ir a un año...</option>
            {years.map((y) => <option value={y}>{y}</option>)}
          </select>
        </div>

        <div class="flex gap-10 items-start">
          <!-- Sidebar: sticky year navigator (desktop only) -->
          <aside class="hidden lg:block w-16 shrink-0 sticky top-6">
            <div class="max-h-[calc(100vh-6rem)] overflow-y-auto text-xs space-y-5 pr-1">
              {[...byDecade.entries()].map(([decade, ys]) => (
                <div>
                  <p class="text-gray-400 font-bold tracking-widest mb-1.5 text-[10px]">
                    {decade}
                  </p>
                  <ul class="space-y-0.5">
                    {ys.map((y) => (
                      <li>
                        <a
                          href={`#year-${y}`}
                          class="year-link block py-0.5 text-gray-400 hover:text-brand-700 transition-colors tabular-nums"
                          data-year={y}
                        >
                          {y}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </aside>

          <!-- Audio list -->
          <div class="flex-1 min-w-0">
            {years.map((year) => (
              <section id={`year-${year}`} class="mb-10 year-section">
                <div class="flex items-center gap-4 mb-3">
                  <h3 class="text-base font-semibold text-brand-700 shrink-0 tabular-nums">{year}</h3>
                  <div class="flex-1 h-px bg-gray-200" />
                  <span class="text-xs text-gray-400 shrink-0">
                    {byYear.get(year)!.length} {byYear.get(year)!.length !== 1 ? "emisiones" : "emisión"}
                  </span>
                </div>
                <ul class="space-y-2">
                  {byYear.get(year)!.map((audio) => (
                    <li class="flex items-baseline gap-4">
                      <span class="text-xs text-gray-400 tabular-nums shrink-0 w-20">
                        {audio.date}
                      </span>
                      <a
                        href={`/audios/${audio.ivoox_id}/`}
                        class="text-brand-700 hover:text-brand-900 hover:underline leading-snug flex-1 min-w-0"
                      >
                        {audio.title}
                      </a>
                      {audio.duration_seconds > 0 && (
                        <span class="text-xs text-gray-400 tabular-nums shrink-0">
                          {formatDuration(audio.duration_seconds)}
                        </span>
                      )}
                    </li>
                  ))}
                </ul>
              </section>
            ))}
          </div>
        </div>
      </>
    )}
  </div>

  <script is:inline>
    (function () {
      var sel = document.getElementById("year-jump");
      if (sel) {
        sel.addEventListener("change", function () {
          if (!sel.value) return;
          var el = document.getElementById("year-" + sel.value);
          if (el) el.scrollIntoView({ behavior: "smooth", block: "start" });
          sel.value = "";
        });
      }
      var sections = Array.from(document.querySelectorAll(".year-section[id]"));
      var links = Array.from(document.querySelectorAll(".year-link"));
      if (!sections.length || !links.length) return;
      function setActive(year) {
        links.forEach(function (l) {
          var on = l.dataset.year === year;
          l.classList.toggle("text-brand-700", on);
          l.classList.toggle("font-bold", on);
          l.classList.toggle("text-gray-400", !on);
        });
      }
      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              setActive(entry.target.id.replace("year-", ""));
            }
          });
        },
        { rootMargin: "-10% 0px -75% 0px", threshold: 0 }
      );
      sections.forEach(function (s) { observer.observe(s); });
    })();
  </script>
</Base>
