---
import { join } from "node:path";
import Base from "../../layouts/Base.astro";
import { loadAllAudios, formatDuration } from "../../lib/audio";

const audiosDir = join(process.cwd(), "..", "ficheros", "publicos", "audios");
const audios = loadAllAudios(audiosDir);

// Group by year — audios already sorted oldest → newest by loadAllAudios
const byYear = new Map<string, typeof audios>();
for (const audio of audios) {
  const year = audio.date.slice(0, 4) || "sin-fecha";
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(audio);
}
const years = [...byYear.keys()].sort();
---

<Base title="Audios" description="Grabaciones de Radio Libertad Constituyente">
  <div class="max-w-3xl">
    <h1 class="text-3xl font-bold font-serif text-brand-900 mb-2">Audios</h1>
    <p class="text-gray-600 mb-8">
      Grabaciones de Radio Libertad Constituyente, el programa del MCRC en iVoox
      con miles de emisiones sobre democracia, república y la obra de García-Trevijano.
    </p>

    <a
      href="https://www.ivoox.com/en/podcast-radio-libertad-constituyente_sq_f125183_93.html"
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-3 px-6 py-4 bg-brand-900 text-white rounded-lg hover:bg-brand-800 transition-colors text-lg"
    >
      Escuchar en iVoox
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>

    {audios.length > 0 && (
      <>
        <div class="flex items-center gap-4 mt-12 mb-8">
          <h2 class="text-xl font-bold font-serif text-brand-900 shrink-0">Transcripciones</h2>
          <div class="flex-1 h-px bg-gray-200" />
          <span class="text-sm text-gray-400 shrink-0">{audios.length} audios</span>
        </div>

        {years.map((year) => (
          <section class="mb-10">
            <div class="flex items-center gap-4 mb-3">
              <h3 class="text-base font-semibold text-brand-700 shrink-0 tabular-nums">{year}</h3>
              <div class="flex-1 h-px bg-gray-200" />
              <span class="text-xs text-gray-400 shrink-0">
                {byYear.get(year)!.length} {byYear.get(year)!.length !== 1 ? "emisiones" : "emisión"}
              </span>
            </div>
            <ul class="space-y-2">
              {byYear.get(year)!.map((audio) => (
                <li class="flex items-baseline gap-4">
                  <span class="text-xs text-gray-400 tabular-nums shrink-0 w-20">
                    {audio.date}
                  </span>
                  <a
                    href={`/audios/${audio.ivoox_id}/`}
                    class="text-brand-700 hover:text-brand-900 hover:underline leading-snug flex-1 min-w-0"
                  >
                    {audio.title}
                  </a>
                  {audio.duration_seconds > 0 && (
                    <span class="text-xs text-gray-400 tabular-nums shrink-0">
                      {formatDuration(audio.duration_seconds)}
                    </span>
                  )}
                </li>
              ))}
            </ul>
          </section>
        ))}
      </>
    )}
  </div>
</Base>
