---
import { join } from "node:path";
import { marked } from "marked";
import Base from "../../layouts/Base.astro";
import { loadAllAudios, formatDuration } from "../../lib/audio";

export function getStaticPaths() {
  const audiosDir = join(process.cwd(), "..", "ficheros", "publicos", "audios");
  return loadAllAudios(audiosDir).map((audio) => ({
    params: { id: audio.ivoox_id },
    props: { audio },
  }));
}

const { audio } = Astro.props;
const html = marked.parse(audio.body) as string;
const audioUrl = audio.audio_cid
  ? `https://ipfs.antoniogarciatrevijano.info/ipfs/${audio.audio_cid}`
  : null;
---

<Base title={audio.title} description={`${audio.title} — Radio Libertad Constituyente`}>
  <div class="max-w-3xl mx-auto">

    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/audios/" class="hover:text-brand-700">Audios</a>
      <span class="mx-1">/</span>
      <span class="text-gray-700">{audio.title}</span>
    </nav>

    <!-- Header -->
    <header class="mb-6">
      <h1 class="text-2xl font-bold font-serif text-brand-900 mb-3 leading-snug">
        {audio.title}
      </h1>
      <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-gray-500">
        {audio.date && <span>{audio.date}</span>}
        {audio.uploader && <span>{audio.uploader}</span>}
        {audio.duration_seconds > 0 && <span>{formatDuration(audio.duration_seconds)}</span>}
        {audio.ivoox_url && (
          <a href={audio.ivoox_url} target="_blank" rel="noopener" class="hover:text-brand-700">
            iVoox ↗
          </a>
        )}
      </div>
    </header>

    <!-- Audio player -->
    {audioUrl && (
      <div class="mb-8">
        <audio controls src={audioUrl} class="w-full" preload="none" />
      </div>
    )}

    <!-- Transcript -->
    <div class="article-body" set:html={html} data-pagefind-body />

  </div>
</Base>
