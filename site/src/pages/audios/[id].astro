---
import { join } from "node:path";
import { marked } from "marked";
import Base from "../../layouts/Base.astro";
import {
  loadAllAudios,
  loadSrt,
  groupIntoTurns,
  formatDuration,
  formatSpeaker,
} from "../../lib/audio";

export function getStaticPaths() {
  const audiosDir = join(process.cwd(), "..", "ficheros", "publicos", "audios");
  return loadAllAudios(audiosDir).map((audio) => ({
    params: { id: audio.ivoox_id },
    props: { audio },
  }));
}

const { audio } = Astro.props;
const audiosDir = join(process.cwd(), "..", "ficheros", "publicos", "audios");

// Description: the optional blockquote block at the top of the .md body,
// before the first horizontal rule. Used for the programme summary.
const descEnd = audio.body.indexOf("\n---\n");
const descMd = descEnd !== -1 ? audio.body.slice(0, descEnd).trim() : "";
const descHtml = descMd ? (marked.parse(descMd) as string) : "";

// Interactive transcript from the .srt file (sentence-level timestamps)
const segments = loadSrt(audiosDir, audio.ivoox_id);
const turns = groupIntoTurns(segments);

const audioUrl = audio.audio_cid
  ? `https://ipfs.antoniogarciatrevijano.info/ipfs/${audio.audio_cid}`
  : null;
---

<Base title={audio.title} description={`${audio.title} — Radio Libertad Constituyente`}>
  <div class="max-w-3xl mx-auto">

    <!-- Sticky panel: breadcrumb + title + metadata + player -->
    <div class="sticky top-0 z-10 bg-white border-b border-gray-100 shadow-sm pt-4 pb-4">

      <nav class="text-sm text-gray-500 mb-3">
        <a href="/audios/" class="hover:text-brand-700">Audios</a>
        <span class="mx-1">/</span>
        <span class="text-gray-700">{audio.title}</span>
      </nav>

      <h1 class="text-2xl font-bold font-serif text-brand-900 mb-2 leading-snug">
        {audio.title}
      </h1>

      <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-gray-500 mb-4">
        {audio.date && <span>{audio.date}</span>}
        {audio.uploader && <span>{audio.uploader}</span>}
        {audio.duration_seconds > 0 && <span>{formatDuration(audio.duration_seconds)}</span>}
        {audio.ivoox_url && (
          <a href={audio.ivoox_url} target="_blank" rel="noopener" class="hover:text-brand-700">
            iVoox ↗
          </a>
        )}
      </div>

      {audioUrl && (
        <audio id="player" controls src={audioUrl} class="w-full" preload="none" />
      )}

    </div>

    <!-- Scrolling content: description + transcript -->
    <div class="pt-6">

      {descHtml && (
        <div class="article-body mb-8" set:html={descHtml} />
      )}

      {turns.length > 0 ? (
        <div class="transcript" data-pagefind-body>
          {turns.map((turn) => (
            <div class="mb-5">
              <p class="text-xs font-semibold text-brand-700 uppercase tracking-wide mb-1">
                {formatSpeaker(turn.speaker)}
              </p>
              <p class="font-serif text-base leading-relaxed">
                {turn.segments.map((seg) => (
                  <span
                    class="seg"
                    data-start={seg.start}
                    data-end={seg.end}
                  >
                    {seg.text}{" "}
                  </span>
                ))}
              </p>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-gray-400 text-sm italic">Transcripción no disponible.</p>
      )}

    </div>

  </div>
</Base>

<script is:inline>
  (function () {
    const audio = document.getElementById("player");
    if (!audio) return;

    // Pre-parse timestamps once at load time to avoid repeated parseFloat on every timeupdate
    const segs = [...document.querySelectorAll(".seg")].map((el) => ({
      el,
      start: parseFloat(el.dataset.start),
      end: parseFloat(el.dataset.end),
    }));
    if (segs.length === 0) return;

    // Click any sentence to seek to that position and start playing
    segs.forEach(({ el, start }) => {
      el.addEventListener("click", () => {
        audio.currentTime = start;
        audio.play();
      });
    });

    // Highlight the sentence currently being spoken
    // Segments are sorted by time, so we can break early once we pass current time
    let currentActive = null;
    audio.addEventListener("timeupdate", () => {
      const t = audio.currentTime;
      let active = null;
      for (const { el, start, end } of segs) {
        if (start > t) break;       // all remaining segments start later
        if (t < end) { active = el; break; } // t falls within this segment
      }
      if (active !== currentActive) {
        currentActive?.classList.remove("seg-active");
        active?.classList.add("seg-active");
        currentActive = active;
      }
    });
  })();
</script>
