---
import { readFileSync } from "node:fs";
import { join } from "node:path";
import { marked } from "marked";
import Base from "../../layouts/Base.astro";
import catalog from "../../data/catalog.json";

export function getStaticPaths() {
  return catalog
    .filter((item) => item.category === "articulos")
    .map((article) => ({
      params: { slug: article.slug },
      props: { article },
    }));
}

const { article } = Astro.props;

// Read and render markdown content
let htmlContent = "";
if (article.has_text && article.markdown_path) {
  const outputDir = join(process.cwd(), "..", "output", "publicos");
  try {
    const md = readFileSync(join(outputDir, article.markdown_path), "utf-8");
    htmlContent = marked.parse(md) as string;
  } catch {
    htmlContent = "<p><em>Texto no disponible.</em></p>";
  }
}

// Find adjacent articles for navigation
const articles = catalog
  .filter((i) => i.category === "articulos")
  .sort((a, b) => (b.date || "0000").localeCompare(a.date || "0000"));
const idx = articles.findIndex((a) => a.slug === article.slug);
const prev = idx > 0 ? articles[idx - 1] : null;
const next = idx < articles.length - 1 ? articles[idx + 1] : null;
---

<Base title={article.title} description={`${article.title} — ${article.publication || ""}${article.date ? `, ${article.date}` : ""}`}>
  <!-- Breadcrumb -->
  <nav class="text-sm text-gray-500 mb-6">
    <a href="/articulos/" class="hover:text-brand-700">Artículos</a>
    <span class="mx-1">/</span>
    <span class="text-gray-900">{article.title}</span>
  </nav>

  <article class="max-w-3xl">
    <!-- Header -->
    <header class="mb-8">
      <h1 class="text-3xl font-bold font-serif text-brand-900 mb-3">{article.title}</h1>
      <div class="flex flex-wrap gap-3 text-sm text-gray-600">
        {article.date && <span>{article.date}</span>}
        {article.publication && (
          <span class="text-brand-700 bg-brand-50 px-2 py-0.5 rounded">
            {article.publication}
          </span>
        )}
        {article.series_number && (
          <span class="text-gray-500">N.º {article.series_number}</span>
        )}
      </div>
      {article.ipfs_url && (
        <a
          href={article.ipfs_url}
          target="_blank"
          rel="noopener"
          class="inline-block mt-3 text-sm text-brand-700 hover:text-brand-900 underline"
        >
          Descargar documento original (IPFS)
        </a>
      )}
    </header>

    <!-- Article text -->
    {htmlContent ? (
      <div class="article-body" set:html={htmlContent} data-pagefind-body />
    ) : (
      <p class="text-gray-500 italic">
        El texto de este artículo no está disponible en formato digital.
        {article.ipfs_url && (
          <a href={article.ipfs_url} class="underline">Descarga el documento original.</a>
        )}
      </p>
    )}

    <!-- Navigation -->
    <nav class="flex justify-between items-start gap-4 mt-12 pt-6 border-t border-gray-200 text-sm">
      {prev ? (
        <a href={`/articulos/${prev.slug}/`} class="text-brand-700 hover:text-brand-900">
          &larr; {prev.title}
        </a>
      ) : <span />}
      {next ? (
        <a href={`/articulos/${next.slug}/`} class="text-right text-brand-700 hover:text-brand-900">
          {next.title} &rarr;
        </a>
      ) : <span />}
    </nav>
  </article>
</Base>
