---
import Base from "../../layouts/Base.astro";
import catalog from "../../data/catalog.json";

const articles = catalog
  .filter((i) => i.category === "prensa")
  .sort((a, b) => (b.date || "0000").localeCompare(a.date || "0000"));

// Extract unique years and publications for filters
const years = [...new Set(articles.map((a) => a.date?.slice(0, 4)).filter(Boolean))].sort().reverse();
const publications = [...new Set(articles.map((a) => a.publication).filter(Boolean))].sort();
---

<Base title="Prensa" description={`${articles.length} recortes de prensa sobre Antonio García-Trevijano`}>
  <h1 class="text-3xl font-bold font-serif text-brand-900 mb-2">Prensa</h1>
  <p class="text-gray-600 mb-6">{articles.length} recortes de prensa entre {years[years.length - 1]} y {years[0]}</p>

  <!-- Filters -->
  <div class="flex flex-wrap gap-3 mb-6">
    <select id="filter-year" aria-label="Filtrar por año" class="border border-gray-300 rounded px-3 py-2 text-sm bg-white">
      <option value="">Todos los años</option>
      {years.map((y) => <option value={y}>{y}</option>)}
    </select>
    <select id="filter-pub" aria-label="Filtrar por publicación" class="border border-gray-300 rounded px-3 py-2 text-sm bg-white">
      <option value="">Todas las publicaciones</option>
      {publications.map((p) => <option value={p}>{p}</option>)}
    </select>
    <span id="filter-count" class="self-center text-sm text-gray-500"></span>
  </div>

  <!-- Article list -->
  <div id="article-list" class="space-y-1">
    {articles.map((article) => (
      <a
        href={`/prensa/${article.slug}/`}
        class="article-row block px-3 py-2.5 rounded hover:bg-brand-50 transition-colors border-b border-gray-100"
        data-year={article.date?.slice(0, 4) || ""}
        data-pub={article.publication || ""}
        data-pagefind-ignore
      >
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-1">
          <span class="text-sm text-gray-400 font-mono shrink-0 w-24">{article.date || "s/f"}</span>
          {article.publication && (
            <span class="text-xs text-brand-700 bg-brand-50 px-2 py-0.5 rounded shrink-0">
              {article.publication}
            </span>
          )}
          <span class="font-medium text-gray-900">{article.title}</span>
        </div>
      </a>
    ))}
  </div>

  <script>
    const yearSelect = document.getElementById("filter-year") as HTMLSelectElement;
    const pubSelect = document.getElementById("filter-pub") as HTMLSelectElement;
    const countSpan = document.getElementById("filter-count")!;
    const rows = document.querySelectorAll<HTMLElement>(".article-row");

    function applyFilters() {
      const year = yearSelect.value;
      const pub = pubSelect.value;
      let visible = 0;
      rows.forEach((row) => {
        const matchYear = !year || row.dataset.year === year;
        const matchPub = !pub || row.dataset.pub === pub;
        const show = matchYear && matchPub;
        row.style.display = show ? "" : "none";
        if (show) visible++;
      });
      countSpan.textContent = `${visible} recortes`;
    }

    yearSelect.addEventListener("change", applyFilters);
    pubSelect.addEventListener("change", applyFilters);
    applyFilters();
  </script>
</Base>
