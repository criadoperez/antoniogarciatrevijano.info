---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Archivo y obra de Antonio García-Trevijano" } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "Inicio" },
  { href: "/cronologia/", label: "Cronología" },
  { href: "/articulos/", label: "Artículos" },
  { href: "/hechos/", label: "Hechos" },
  { href: "/blog/", label: "Blog" },
  { href: "/fotos/", label: "Fotos" },
  { href: "/libros/", label: "Libros" },
  { href: "/audios/", label: "Audios" },
  { href: "/videos/", label: "Vídeos" },
  { href: "/chat/", label: "Chat IA" },
];

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} — Antonio García-Trevijano</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  </head>
  <body class="min-h-screen flex flex-col bg-white text-gray-900 font-sans">
    <!-- Header -->
    <header class="bg-brand-900 text-white">
      <div class="max-w-6xl mx-auto px-4 py-4 flex flex-col sm:flex-row items-center justify-between gap-3">
        <a href="/" class="text-xl font-bold tracking-tight hover:text-brand-100 transition-colors">
          Antonio García-Trevijano
        </a>
        <nav class="flex flex-wrap gap-1 text-sm">
          {navLinks.map(({ href, label }) => (
            <a
              href={href}
              class:list={[
                "px-3 py-1.5 rounded transition-colors",
                isActive(href)
                  ? "bg-white/20 text-white font-medium"
                  : "text-brand-100 hover:bg-white/10 hover:text-white",
              ]}
            >
              {label}
            </a>
          ))}
        </nav>
      </div>
      <!-- Search bar — always visible, Pagefind enhances it when available -->
      <div class="max-w-6xl mx-auto px-4 pb-3">
        <div id="search" class="pagefind-search">
          <input
            id="search-fallback"
            type="text"
            placeholder="Buscar en todos los artículos..."
            class="w-full rounded-lg border border-white/30 bg-white/15 px-4 py-2 text-sm text-white placeholder-white/60 focus:bg-white/25 focus:border-white/50 focus:outline-none"
          />
        </div>
      </div>
    </header>

    <script is:inline src="/pagefind/pagefind-ui.js"></script>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', function() {
        if (typeof PagefindUI === 'undefined') return;
        // Remove fallback input — Pagefind will create its own
        var fallback = document.getElementById('search-fallback');
        if (fallback) fallback.remove();
        new PagefindUI({
          element: "#search",
          showSubResults: false,
          showImages: false,
          translations: {
            placeholder: "Buscar en todos los artículos...",
            zero_results: "No se encontraron resultados para [SEARCH_TERM]",
          }
        });
      });
    </script>

    <!-- Main content -->
    <main class="flex-1 max-w-6xl mx-auto px-4 py-8 w-full">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-brand-50 border-t border-brand-100 text-gray-600 text-sm">
      <div class="max-w-6xl mx-auto px-4 py-6 flex flex-col sm:flex-row items-center justify-between gap-2">
        <p>Archivo dedicado a la memoria de Antonio García-Trevijano (1928–2018)</p>
        <span class="flex items-center gap-2">
          <span>Contenido almacenado en IPFS</span>
          <a href="https://github.com/criadoperez/antoniogarciatrevijano.info/" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="text-gray-400 hover:text-gray-700 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
        </span>
      </div>
    </footer>
  </body>
</html>
